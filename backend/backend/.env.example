# API Keys
ANTHROPIC_API_KEY=sk-ant-v0-your-key-here
CLAUDE_MODEL=claude-opus-4-5

# Database (SQLite by default, use PostgreSQL for production)
DATABASE_URL=sqlite:///./catalogai.db
# DATABASE_URL=postgresql://user:password@localhost:5432/catalogai

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Google Drive (optional)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=false

# Limits
MAX_FILE_SIZE=524288000
MAX_IMAGES_PER_JOB=500
DAILY_BUDGET=5.0
